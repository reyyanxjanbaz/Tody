{
  "name": "web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "preview": "vite preview",
    "test": "npm run test:parity && npm run test:unit && npm run test:e2e",
    "test:unit": "NODE_OPTIONS=--no-experimental-webstorage vitest run tests/phase0 tests/phase1 tests/phase2 tests/phase5-habits tests/phaseA tests/phaseB tests/phaseC tests/phaseD tests/phaseE tests/phaseF",
    "test:parity": "NODE_OPTIONS=--no-experimental-webstorage vitest run tests/parity",
    "test:artifacts": "NODE_OPTIONS=--no-experimental-webstorage vitest run tests/phase4/*.artifacts.test.ts tests/phase4/*.test.tsx",
    "test:e2e": "playwright test tests/phase3 tests/phase4",
    "test:gaps": "playwright test tests/parity-gaps",
    "test:phase0": "vitest run tests/phase0",
    "test:phase1": "vitest run tests/phase1",
    "test:phase2": "vitest run tests/phase2",
    "test:phase3": "playwright test tests/phase3",
    "test:phase4": "npm run test:artifacts && playwright test tests/phase4",
    "test:phase5": "NODE_OPTIONS=--no-experimental-webstorage vitest run tests/phase5-habits"
  },
  "dependencies": {
    "@formkit/auto-animate": "^0.9.0",
    "@supabase/supabase-js": "^2.110.0",
    "@tanstack/react-virtual": "^3.14.5",
    "@use-gesture/react": "^10.3.1",
    "framer-motion": "^12.42.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-icons": "^5.7.0",
    "react-router-dom": "^7.18.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.9",
    "jsdom": "^29.1.1",
    "oxlint": "^1.71.0",
    "playwright-core": "^1.61.1",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.9"
  }
}
